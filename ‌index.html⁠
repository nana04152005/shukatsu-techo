/* ---------- helpers ---------- */
function daysUntil(dateStr) {
  if (!dateStr) return null;
  const d = new Date(dateStr + "T00:00:00");
  const now = new Date();
  now.setHours(0, 0, 0, 0);
  return Math.round((d - now) / 86400000);
}

function deadlineTone(days) {
  if (days === null) return C.mute;
  if (days < 0) return C.mute;
  if (days <= 3) return C.coral;
  if (days <= 7) return C.amber;
  return C.sage;
}

/* ---------- route-map progress (signature element) ---------- */
function RouteLine({ stage, status, rounds, compact }) {
  const stages = getStages(rounds);
  const idx = stageIdxIn(stages, stage);
  const dead = status === "rejected" || status === "withdrawn";
  return (
    <div className="flex items-center w-full" style={{ opacity: dead ? 0.45 : 1 }}>
      {stages.map((s, i) => {
        const done = i < idx || (i === idx && !dead);
        const current = i === idx;
        return (
          <div key={s.key} className="flex items-center flex-1 last:flex-none">
            <div className="flex flex-col items-center" style={{ minWidth: compact ? 0 : 34 }}>
              <div
                style={{
                  width: current ? 14 : 9,
                  height: current ? 14 : 9,
                  borderRadius: 999,
                  background: current ? (dead ? C.mute : C.indigo) : done ? C.indigo : "#fff",
                  border: `2px solid ${done || current ? C.indigo : C.hairline}`,
                  boxShadow: current ? `0 0 0 3px ${C.indigoSoft}` : "none",
                  transition: "all .15s",
                  flexShrink: 0,
                }}
              />
              {!compact && (
                <span
                  className="text-[9px] mt-1 whitespace-nowrap"
                  style={{
                    color: current ? C.ink : C.inkSoft,
                    fontWeight: current ? 700 : 400,
                    fontFamily: "'Zen Kaku Gothic New', sans-serif",
                  }}
                >
                  {s.short}
                </span>
              )}
            </div>
            {i < stages.length - 1 && (
              <div
                className="flex-1"
                style={{
                  height: 2,
                  minWidth: 6,
                  background: i < idx ? C.indigo : C.hairline,
                  marginBottom: compact ? 0 : 14,
                }}
              />
            )}
          </div>
        );
      })}
    </div>
  );
}

/* ---------- stat pill ---------- */
function StatPill({ label, value, color, bg, onClick, active }) {
