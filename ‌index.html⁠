}

/* ---------- company card ---------- */
function CompanyCard({ c, onOpen }) {
  const days = daysUntil(c.deadline);
  const dead = c.status === "rejected" || c.status === "withdrawn";

  return (
    <button
      onClick={() => onOpen(c.id)}
      className="text-left w-full rounded-2xl p-4 mb-2.5 transition-transform active:scale-[0.99]"
      style={{
        background: C.paperRaised,
        border: `1px solid ${C.hairline}`,
        boxShadow: "0 1px 2px rgba(32,36,43,0.04)",
      }}
    >
      <div className="flex items-start justify-between gap-2 mb-2">
        <span
          className="truncate text-[15px] min-w-0"
          style={{
            fontFamily: "'Shippori Mincho', serif",
            fontWeight: 700,
            color: dead ? C.mute : C.ink,
            textDecoration: c.status === "withdrawn" ? "line-through" : "none",
          }}
        >
          {c.name}
        </span>
        {dead ? (
          <span
            className="text-[11px] px-2 py-0.5 rounded-full shrink-0"
            style={{ background: C.muteSoft, color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}
          >
            {c.status === "rejected" ? "不採用" : "辞退"}
          </span>
        ) : days !== null ? (
          <span
            className="text-[11px] px-2 py-0.5 rounded-full shrink-0 whitespace-nowrap"
            style={{ background: deadlineTone(days) + "22", color: deadlineTone(days), fontFamily: "'Zen Kaku Gothic New', sans-serif" }}
          >
            {days < 0 ? "期限切れ" : days === 0 ? "本日締切" : `あと${days}日`}
          </span>
        ) : null}
      </div>
      <div className="flex items-center justify-between mb-3">
        <span className="text-[12px]" style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>
          {c.industry || "業界未設定"}
        </span>
        <StarRating value={c.priority} readOnly size={12} />
      </div>
      <RouteLine stage={c.stage} status={c.status} rounds={c.interviewRounds} />
    </button>
  );
}

