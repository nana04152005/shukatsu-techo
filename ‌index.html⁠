  const [c, setC] = useState(company);

  useEffect(() => {
    setC(company);
  }, [company]);

  const update = (patch) => {
    const next = { ...c, ...patch };
    setC(next);
    onChange(next);
  };

  const rounds = c.interviewRounds || DEFAULT_ROUNDS;
  const stages = getStages(rounds);

  const setStage = (key) => {
    const hist = [...(c.history || [])];
    if (!hist.find((h) => h.stage === key)) {
      hist.push({ stage: key, date: new Date().toISOString().slice(0, 10) });
    }
    update({ stage: key, status: "active", history: hist });
  };

  const addRound = () => {
    if (rounds >= MAX_ROUNDS) return;
    update({ interviewRounds: rounds + 1 });
  };
  const removeRound = () => {
    if (rounds <= 1) return;
    if (c.stage === `interview${rounds}`) {
      alert("現在その面接回が選択されているため削除できません。先に別のステージへ移動してください。");
      return;
    }
    update({ interviewRounds: rounds - 1 });
  };

  const addEvent = () => {
    update({
      events: [
        ...(c.events || []),
        { id: uid(), title: "", date: c.deadline || todayStr(), time: "", type: "interview" },
