            <div className="text-center py-16">
              <p className="text-[13px]" style={{ color: C.mute }}>
                {companies.length === 0 ? "まだ企業が登録されていません" : "該当する企業がありません"}
              </p>
              {companies.length === 0 && (
                <button
                  onClick={() => setShowAdd(true)}
                  className="mt-3 text-[13px] px-4 py-2 rounded-full"
                  style={{ background: C.indigoSoft, color: C.indigo }}
                >
                  最初の企業を追加する
                </button>
              )}
            </div>
          ) : (
            groupedKeys.map((key) => {
              const items = grouped[key] || [];
              if (items.length === 0) return null;
              return (
                <div key={key} className="mb-5">
                  <div className="flex items-center gap-2 mb-2 px-1">
                    <span
                      className="text-[12px] px-2 py-0.5 rounded-md"
                      style={{ background: C.indigoSoft, color: C.indigo, fontWeight: 700 }}
                    >
                      {labelForStage(key)}
                    </span>
                    <span className="text-[11px]" style={{ color: C.mute }}>
                      {items.length}社
                    </span>
                  </div>
                  {items.map((c) => (
                    <CompanyCard key={c.id} c={c} onOpen={setOpenId} />
                  ))}
                </div>
              );
            })
          )}
        </div>
      )}

      {openCompany && (
        <Detail
          company={openCompany}
          onChange={updateCompany}
          onClose={() => setOpenId(null)}
          onDelete={deleteCompany}
          industryHistory={industryHistory}
          recordIndustry={recordIndustry}
          removeIndustry={removeIndustry}
        />
      )}
      {showAdd && <AddModal onAdd={addCompany} onClose={() => setShowAdd(false)} recordIndustry={recordIndustry} />}

      {openGeneralEvent && (
        <GeneralEventDetail
          event={openGeneralEvent}
          onChange={updateGeneralEvent}
          onClose={() => setOpenGeneralEventId(null)}
          onDelete={deleteGeneralEvent}
        />
      )}
    </div>
  );
}

const rootEl = document.getElementById("root");
const root = ReactDOM.createRoot(rootEl);
root.render(<AuthGate />);
</script>
</body>
</html>
