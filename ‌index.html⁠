/* ---------- supabase-backed storage adapter (same interface as window.storage) ---------- */
function installSupabaseStorage(userId) {
  window.storage = {
    async get(key, shared) {
      const { data, error } = await sb
        .from("kv_store")
        .select("value")
        .eq("user_id", userId)
        .eq("key", key)
        .eq("shared", !!shared)
        .maybeSingle();
      if (error) throw error;
      if (!data) throw new Error("key not found: " + key);
      return { key, value: data.value, shared: !!shared };
    },
    async set(key, value, shared) {
      const { error } = await sb.from("kv_store").upsert(
        { user_id: userId, key, shared: !!shared, value, updated_at: new Date().toISOString() },
        { onConflict: "user_id,key,shared" }
      );
      if (error) throw error;
      return { key, value, shared: !!shared };
    },
    async delete(key, shared) {
      const { error } = await sb
        .from("kv_store")
        .delete()
        .eq("user_id", userId)
        .eq("key", key)
        .eq("shared", !!shared);
      if (error) throw error;
      return { key, deleted: true, shared: !!shared };
    },
    async list(prefix, shared) {
      let q = sb.from("kv_store").select("key").eq("user_id", userId).eq("shared", !!shared);
      if (prefix) q = q.like("key", prefix + "%");
      const { data, error } = await q;
      if (error) throw error;
      return { keys: (data || []).map((r) => r.key), prefix, shared: !!shared };
    },
  };
}

/* ---------- login / signup gate ---------- */
function AuthGate() {
  const [session, setSession] = useState(undefined); // undefined = loading, null = logged out
  const [mode, setMode] = useState("signin"); // signin | signup
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [busy, setBusy] = useState(false);
  const [message, setMessage] = useState("");

  useEffect(() => {
    if (!sb) return;
    sb.auth.getSession().then(({ data }) => setSession(data.session || null));
    const { data: sub } = sb.auth.onAuthStateChange((_event, s) => setSession(s));
    return () => sub.subscription.unsubscribe();
  }, []);

  if (!sb) {
    return (
      <div style={{ padding: 24, fontFamily: "'Zen Kaku Gothic New', sans-serif", color: C.ink }}>
        <h2 style={{ fontFamily: "'Shippori Mincho', serif" }}>設定が必要です</h2>
        <p style={{ color: C.inkSoft, fontSize: 13, lineHeight: 1.7 }}>
          このファイル上部の SUPABASE_URL と SUPABASE_ANON_KEY を、あなたの Supabase プロジェクトの値に書き換えてから、もう一度デプロイしてください。
        </p>
      </div>
    );
  }

  if (session === undefined) {
    return (
      <div className="h-screen flex items-center justify-center" style={{ background: C.paper }}>
        <span style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>読み込み中…</span>
      </div>
    );
  }

  if (session) {
    installSupabaseStorage(session.user.id);
    return (
      <App
        userEmail={session.user.email}
        onSignOut={() => {
          sb.auth.signOut();
          window.location.reload();
        }}
      />
    );
  }

  const submit = async () => {
    if (!email.trim() || !password) return;
    setBusy(true);
    setMessage("");
    try {
      if (mode === "signup") {
        const { error } = await sb.auth.signUp({ email: email.trim(), password });
        if (error) throw error;
        setMessage("確認メールを送りました。メール内のリンクを開いてからログインしてください。");
      } else {
        const { error } = await sb.auth.signInWithPassword({ email: email.trim(), password });
        if (error) throw error;
      }
    } catch (err) {
      setMessage(err.message || "エラーが発生しました");
    }
    setBusy(false);
  };

  const inputStyle = {
    background: C.paperRaised,
    border: `1px solid ${C.hairline}`,
    fontFamily: "'Zen Kaku Gothic New', sans-serif",
  };

  return (
    <div className="min-h-screen flex items-center justify-center px-6" style={{ background: C.paper }}>
      <div className="w-full max-w-[340px]">
        <h1
          className="text-center mb-1"
          style={{ fontFamily: "'Shippori Mincho', serif", fontWeight: 800, fontSize: 24, color: C.ink }}
        >
          就活手帳
        </h1>
        <p className="text-center mb-6 text-[12px]" style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>
          {mode === "signup" ? "アカウントを作成" : "ログイン"}
        </p>

        <input
          value={email}
          onChange={(e) => setEmail(e.target.value)}
          placeholder="メールアドレス"
          type="email"
          className="w-full px-3 py-2.5 rounded-xl outline-none mb-2 text-[14px]"
          style={inputStyle}
        />
        <input
          value={password}
          onChange={(e) => setPassword(e.target.value)}
          placeholder="パスワード（6文字以上）"
          type="password"
          className="w-full px-3 py-2.5 rounded-xl outline-none mb-4 text-[14px]"
          style={inputStyle}
        />

        <button
          onClick={submit}
          disabled={busy}
          className="w-full py-2.5 rounded-xl text-[14px] mb-3"
          style={{ background: C.indigo, color: "#fff", fontFamily: "'Zen Kaku Gothic New', sans-serif" }}
        >
          {busy ? "処理中…" : mode === "signup" ? "アカウントを作成" : "ログイン"}
        </button>

        <button
          onClick={() => {
            setMode(mode === "signup" ? "signin" : "signup");
            setMessage("");
          }}
          className="w-full text-center text-[12px]"
          style={{ color: C.indigo, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}
        >
          {mode === "signup" ? "すでにアカウントをお持ちの方はこちら" : "アカウントをお持ちでない方はこちら"}
        </button>

        {message && (
          <p className="text-center text-[12px] mt-4" style={{ color: message.includes("送り") ? C.indigo : C.coral }}>
            {message}
          </p>
        )}
      </div>
    </div>
  );
}

