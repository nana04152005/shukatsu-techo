          className="w-full px-3 py-2 rounded-xl outline-none text-[13px] mb-3"
          style={inputStyle}
        />

        <Label>メモ</Label>
        <textarea
          value={ev.note || ""}
          onChange={(e) => update({ note: e.target.value })}
          placeholder="補足メモ（任意）"
          rows={3}
          className="w-full px-3 py-2 rounded-xl outline-none text-[13px] resize-none mb-3"
          style={inputStyle}
        />

        <PhotoField photo={ev.photo} onChange={(p) => update({ photo: p })} />
      </div>
    </div>
  );
}

/* ---------- mypage view ---------- */
function MyPageView({ companies, onOpenCompany }) {
  const [copiedId, setCopiedId] = useState(null);
  const [query, setQuery] = useState("");
  const [filter, setFilter] = useState("active"); // active | all | done | offer | interested | es | test | interview
  const [starFilter, setStarFilter] = useState(0); // 0 = no filter, 1-5 = exact star count

  const copy = async (text, id) => {
    try {
      await navigator.clipboard.writeText(text);
      setCopiedId(id);
      setTimeout(() => setCopiedId(null), 1500);
    } catch {
      /* clipboard unavailable */
    }
  };

  const filtered = useMemo(() => {
    let list = companies;
    if (filter === "active") list = list.filter((c) => c.status === "active");
    if (filter === "done") list = list.filter((c) => c.status !== "active");
    if (filter === "offer") list = list.filter((c) => c.stage === "offer" && c.status === "active");
    if (filter === "interested") list = list.filter((c) => c.stage === "interested");
    if (filter === "es") list = list.filter((c) => c.stage === "es");
    if (filter === "test") list = list.filter((c) => c.stage === "test");
    if (filter === "interview") list = list.filter((c) => c.stage.startsWith("interview") || c.stage === "final");
    if (starFilter > 0) list = list.filter((c) => (c.priority || 0) === starFilter);
    if (query.trim()) {
      const q = query.trim().toLowerCase();
      list = list.filter((c) => c.name.toLowerCase().includes(q) || (c.industry || "").toLowerCase().includes(q));
    }
    return list;
  }, [companies, filter, starFilter, query]);

  const sorted = filtered
    .slice()
    .sort((a, b) => {
      const aSet = a.mypageUrl ? 1 : 0;
      const bSet = b.mypageUrl ? 1 : 0;
      if (aSet !== bSet) return bSet - aSet;
      return a.name.localeCompare(b.name, "ja");
    });

  const inputStyle = {
    background: C.paperRaised,
    border: `1px solid ${C.hairline}`,
    fontFamily: "'Zen Kaku Gothic New', sans-serif",
  };

  return (
    <div className="px-4 pb-24">
      <p className="text-[12px] mb-3 px-1" style={{ color: C.inkSoft }}>
        各社の採用マイページのURL・ログイン情報を一覧で確認できます
      </p>

      {/* search */}
      <div
        className="flex items-center gap-2 px-3 py-2 rounded-xl mb-2.5"
        style={{ background: C.paperRaised, border: `1px solid ${C.hairline}` }}
      >
        <Search size={14} style={{ color: C.mute }} />
        <input
          value={query}
          onChange={(e) => setQuery(e.target.value)}
          placeholder="企業名・業界で検索"
          className="flex-1 outline-none bg-transparent text-[13px]"
          style={{ color: C.ink }}
        />
      </div>

      {/* filter chips */}
      <div className="flex gap-1.5 flex-wrap mb-2.5">
        {[
          ["interested", "検討"],
          ["active", "選考中"],
          ["offer", "内定"],
          ["done", "不採用・辞退"],
          ["all", "すべて"],
          ["es", "ES"],
          ["test", "適性検査"],
          ["interview", "面接"],
        ].map(([k, l]) => (
          <button
            key={k}
            onClick={() => setFilter(k)}
            className="text-[12px] px-3 py-1.5 rounded-full"
            style={{
              background: filter === k ? C.ink : "transparent",
              color: filter === k ? "#fff" : C.inkSoft,
              border: `1px solid ${filter === k ? C.ink : C.hairline}`,
            }}
          >
            {l}
          </button>
        ))}
      </div>

      {/* star filter */}
      <div className="flex items-center gap-1.5 flex-wrap mb-4">
        <span className="text-[12px]" style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>
          志望度
        </span>
        {[1, 2, 3, 4, 5].map((n) => (
          <button
            key={n}
            onClick={() => setStarFilter((prev) => (prev === n ? 0 : n))}
            className="flex items-center gap-0.5 text-[12px] px-2.5 py-1 rounded-full"
            style={{
              background: starFilter === n ? C.amber : "transparent",
              color: starFilter === n ? "#fff" : C.inkSoft,
              border: `1px solid ${starFilter === n ? C.amber : C.hairline}`,
            }}
          >
            <Star size={11} fill={starFilter === n ? "#fff" : "none"} />
            {n}
          </button>
        ))}
      </div>

      {companies.length === 0 ? (
        <p className="text-center text-[13px] py-10" style={{ color: C.mute }}>
          まだ企業が登録されていません
        </p>
      ) : sorted.length === 0 ? (
        <p className="text-center text-[13px] py-10" style={{ color: C.mute }}>
          該当する企業がありません
        </p>
      ) : (
        <div className="space-y-2.5">
          {sorted.map((c) => {
            const dead = c.status === "rejected" || c.status === "withdrawn";
            return (
              <div
                key={c.id}
                className="rounded-2xl p-4"
                style={{ background: C.paperRaised, border: `1px solid ${C.hairline}`, opacity: dead ? 0.55 : 1 }}
              >
                <button onClick={() => onOpenCompany(c.id)} className="w-full text-left mb-2">
                  <div className="flex items-center gap-2">
                    <span
                      style={{
                        fontFamily: "'Shippori Mincho', serif",
                        fontWeight: 700,
                        fontSize: 15,
                        color: C.ink,
                      }}
                    >
                      {c.name}
                    </span>
                    <span className="text-[11px]" style={{ color: C.mute }}>
                      {c.industry}
                    </span>
                  </div>
                </button>

                {c.mypageUrl ? (
                  <div className="space-y-1.5">
                    <a
                      href={c.mypageUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="flex items-center gap-1.5 text-[12px] truncate"
                      style={{ color: C.indigo }}
                    >
                      <ExternalLink size={12} className="shrink-0" />
                      <span className="truncate">{c.mypageUrl}</span>
                    </a>
                    {c.mypageId && (
                      <div className="flex items-center gap-2">
                        <span
                          className="text-[12px] px-2 py-1 rounded-lg flex-1 truncate"
                          style={{ background: C.paper, color: C.inkSoft }}
                        >
                          {c.mypageId}
                        </span>
                        <button
                          onClick={() => copy(c.mypageId, c.id)}
                          className="text-[11px] px-2 py-1 rounded-lg shrink-0"
                          style={{ background: C.indigoSoft, color: C.indigo }}
                        >
                          {copiedId === c.id ? "コピー済み" : "コピー"}
                        </button>
                      </div>
                    )}
                    {c.mypageNote && (
                      <p className="text-[11px]" style={{ color: C.mute }}>
                        {c.mypageNote}
                      </p>
                    )}
                  </div>
                ) : (
                  <button
                    onClick={() => onOpenCompany(c.id)}
                    className="text-[12px] px-3 py-1.5 rounded-full"
                    style={{ background: C.muteSoft, color: C.inkSoft }}
                  >
                    マイページ未登録・タップして追加
                  </button>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

/* ---------- main app ---------- */
function App({ userEmail, onSignOut } = {}) {
  const [companies, setCompanies, loaded] = useCompanies();
  const [industryHistory, recordIndustry, removeIndustry] = useIndustryHistory();
  const [generalEvents, setGeneralEvents, generalEventsLoaded] = useGeneralEvents();
  const [openId, setOpenId] = useState(null);
  const [openGeneralEventId, setOpenGeneralEventId] = useState(null);
  const [showAdd, setShowAdd] = useState(false);
  const [query, setQuery] = useState("");
  const [filter, setFilter] = useState("active"); // active | all | done | offer | interested | es | test | interview
  const [starFilter, setStarFilter] = useState(0); // 0 = no filter, 1-5 = exact star count
  const [view, setView] = useState("list"); // list | calendar | mypage

  useEffect(() => {
    const link = document.createElement("link");
    link.rel = "stylesheet";
    link.href = "https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700;800&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap";
    document.head.appendChild(link);
    return () => document.head.removeChild(link);
  }, []);

  const updateCompany = (next) => {
    setCompanies((prev) => prev.map((c) => (c.id === next.id ? next : c)));
  };
  const deleteCompany = (id) => {
    setCompanies((prev) => prev.filter((c) => c.id !== id));
  };
  const addEventToCompany = (companyId, event) => {
    setCompanies((prev) =>
      prev.map((c) => (c.id === companyId ? { ...c, events: [...(c.events || []), event] } : c))
    );
  };
  const addGeneralEvent = (event) => {
    setGeneralEvents((prev) => [...prev, event]);
  };
  const updateGeneralEvent = (next) => {
    setGeneralEvents((prev) => prev.map((e) => (e.id === next.id ? next : e)));
  };
  const deleteGeneralEvent = (id) => {
    setGeneralEvents((prev) => prev.filter((e) => e.id !== id));
  };

  const addCompany = ({ name, industry }) => {
    const nc = {
      id: uid(),
      name,
      industry,
      url: "",
      mypageUrl: "",
      mypageId: "",
      mypageNote: "",
      priority: 3,
      stage: "interested",
      interviewRounds: DEFAULT_ROUNDS,
      status: "active",
      deadline: "",
      memo: "",
      events: [],
      es: [],
      photos: [],
      history: [{ stage: "interested", date: new Date().toISOString().slice(0, 10) }],
    };
    setCompanies((prev) => [nc, ...prev]);
    setOpenId(nc.id);
  };

  const filtered = useMemo(() => {
    let list = companies;
    if (filter === "active") list = list.filter((c) => c.status === "active");
    if (filter === "done") list = list.filter((c) => c.status !== "active");
    if (filter === "offer") list = list.filter((c) => c.stage === "offer" && c.status === "active");
    if (filter === "interested") list = list.filter((c) => c.stage === "interested");
    if (filter === "es") list = list.filter((c) => c.stage === "es");
    if (filter === "test") list = list.filter((c) => c.stage === "test");
    if (filter === "interview") list = list.filter((c) => c.stage.startsWith("interview") || c.stage === "final");
    if (starFilter > 0) list = list.filter((c) => (c.priority || 0) === starFilter);
    if (query.trim()) {
      const q = query.trim().toLowerCase();
      list = list.filter((c) => c.name.toLowerCase().includes(q) || (c.industry || "").toLowerCase().includes(q));
    }
    return list;
  }, [companies, filter, starFilter, query]);

  const groupedKeys = useMemo(() => {
    const keys = new Set(filtered.map((c) => c.stage));
    return Array.from(keys).sort((a, b) => orderValue(a) - orderValue(b));
  }, [filtered]);

  const grouped = useMemo(() => {
    const g = {};
    filtered.forEach((c) => {
      if (!g[c.stage]) g[c.stage] = [];
      g[c.stage].push(c);
    });
    return g;
  }, [filtered]);

  const stats = useMemo(() => {
    const active = companies.filter((c) => c.status === "active");
    const offer = companies.filter((c) => c.stage === "offer" && c.status === "active").length;
    const upcoming = companies
      .filter((c) => c.status === "active" && c.deadline)
      .map((c) => ({ c, d: daysUntil(c.deadline) }))
      .filter((x) => x.d !== null && x.d >= 0)
      .sort((a, b) => a.d - b.d);
    return { total: companies.length, active: active.length, offer, nearest: upcoming[0] };
  }, [companies]);

  const openCompany = companies.find((c) => c.id === openId);
  const openGeneralEvent = generalEvents.find((e) => e.id === openGeneralEventId);

  if (!loaded || !generalEventsLoaded) {
    return (
      <div className="h-screen flex items-center justify-center" style={{ background: C.paper }}>
        <span style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>読み込み中…</span>
      </div>
    );
  }

  return (
    <div className="min-h-screen" style={{ background: C.paper, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>
      <datalist id="industry-history-options">
        {industryHistory.map((h) => (
          <option value={h} key={h} />
        ))}
      </datalist>

      {/* header */}
      <div className="px-4 pt-6 pb-3" style={{ background: C.paper }}>
        <div className="flex items-center justify-between mb-1">
          <div className="flex items-center gap-2">
            <div
              className="w-8 h-8 rounded-lg flex items-center justify-center"
              style={{ background: C.indigo }}
            >
              <Building2 size={16} color="#fff" />
            </div>
            <h1 style={{ fontFamily: "'Shippori Mincho', serif", fontWeight: 800, fontSize: 22, color: C.ink }}>
              就活手帳
            </h1>
          </div>
          <div className="flex items-center gap-1.5">
            {onSignOut && (
              <button
                onClick={onSignOut}
                className="text-[11px] px-2.5 py-1.5 rounded-full flex items-center gap-1"
                style={{ background: C.paperRaised, color: C.inkSoft, border: `1px solid ${C.hairline}` }}
                title={userEmail || ""}
              >
                <Check size={12} />
                {userEmail ? userEmail.split("@")[0] : "アカウント"}
              </button>
            )}
          </div>
        </div>
        <p className="text-[12px] mb-3" style={{ color: C.inkSoft }}>
          選考状況・企業情報・ESをひとつにまとめて管理
        </p>

        {/* view toggle */}
        <div
          className="flex p-1 rounded-xl mb-4 overflow-x-auto"
          style={{ background: C.muteSoft }}
        >
          {[
            ["list", "一覧"],
            ["calendar", "カレンダー"],
            ["mypage", "マイページ"],
          ].map(([k, l]) => (
            <button
              key={k}
              onClick={() => setView(k)}
              className="flex-1 text-[13px] py-1.5 rounded-lg transition-colors whitespace-nowrap px-2"
              style={{
                background: view === k ? C.paperRaised : "transparent",
                color: view === k ? C.ink : C.inkSoft,
                fontWeight: view === k ? 700 : 400,
                fontFamily: "'Zen Kaku Gothic New', sans-serif",
                boxShadow: view === k ? "0 1px 2px rgba(32,36,43,0.08)" : "none",
              }}
            >
