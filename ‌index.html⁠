/* ---------- calendar view ---------- */
function buildCalendarEvents(companies, generalEvents) {
  const items = [];
  companies.forEach((c) => {
    if (c.status !== "active") return;
    (c.events || []).forEach((ev) => {
      if (!ev.date) return;
      items.push({
        id: ev.id,
        source: "company",
        companyId: c.id,
        companyName: c.name,
        title: ev.title || eventTypeMeta(ev.type).label,
        date: ev.date,
        time: ev.time || "",
        type: ev.type || "other",
        location: ev.location || "",
        note: ev.note || "",
        photo: ev.photo || null,
        testKind: ev.testKind,
        testKindOther: ev.testKindOther,
        testMethod: ev.testMethod,
        testMethodOther: ev.testMethodOther,
        priority: c.priority,
      });
    });
    // legacy deadline field: include only if no event already covers that exact date
    if (c.deadline) {
      const covered = (c.events || []).some((ev) => ev.date === c.deadline && ev.type === "deadline");
      if (!covered) {
        items.push({
          id: `deadline-${c.id}`,
          source: "company",
          companyId: c.id,
          companyName: c.name,
          title: "締切",
          date: c.deadline,
          time: "",
          type: "deadline",
          priority: c.priority,
        });
      }
    }
  });
  (generalEvents || []).forEach((ev) => {
    if (!ev.date) return;
    items.push({
      id: ev.id,
      source: "general",
      companyId: null,
      companyName: null,
      title: ev.title || eventTypeMeta(ev.type).label,
      date: ev.date,
      time: ev.time || "",
      type: ev.type || "other",
      location: ev.location || "",
      note: ev.note || "",
      photo: ev.photo || null,
      testKind: ev.testKind,
      testKindOther: ev.testKindOther,
      testMethod: ev.testMethod,
      testMethodOther: ev.testMethodOther,
    });
  });
  return items;
}

function CalendarView({ companies, generalEvents, onOpenCompany, onAddEvent, onAddGeneralEvent, onOpenGeneralEvent }) {
  const now = new Date();
  const [cursor, setCursor] = useState({ y: now.getFullYear(), m: now.getMonth() });
  const [selected, setSelected] = useState(todayStr());
  const [showAddEvent, setShowAddEvent] = useState(false);

  const allEvents = useMemo(() => buildCalendarEvents(companies, generalEvents), [companies, generalEvents]);

  const byDate = useMemo(() => {
    const map = {};
    allEvents.forEach((e) => {
      if (!map[e.date]) map[e.date] = [];
      map[e.date].push(e);
    });
    Object.values(map).forEach((list) => list.sort((a, b) => (a.time || "").localeCompare(b.time || "")));
    return map;
  }, [allEvents]);

  const { y, m } = cursor;
  const firstOfMonth = new Date(y, m, 1);
  const startWeekday = firstOfMonth.getDay();
  const daysInMonth = new Date(y, m + 1, 0).getDate();
  const daysInPrevMonth = new Date(y, m, 0).getDate();

  const cells = [];
  for (let i = 0; i < startWeekday; i++) {
    cells.push({ d: daysInPrevMonth - startWeekday + 1 + i, inMonth: false, y: m === 0 ? y - 1 : y, m: m === 0 ? 11 : m - 1 });
  }
  for (let d = 1; d <= daysInMonth; d++) {
    cells.push({ d, inMonth: true, y, m });
  }
  while (cells.length % 7 !== 0) {
    const next = cells.length - (startWeekday + daysInMonth) + 1;
    cells.push({ d: next, inMonth: false, y: m === 11 ? y + 1 : y, m: m === 11 ? 0 : m + 1 });
  }

  const today = todayStr();
  const selectedEvents = (byDate[selected] || []).slice().sort((a, b) => (a.date + a.time).localeCompare(b.date + b.time));

  const goMonth = (delta) => {
    let ny = y, nm = m + delta;
    if (nm < 0) { nm = 11; ny -= 1; }
    if (nm > 11) { nm = 0; ny += 1; }
    setCursor({ y: ny, m: nm });
  };

  return (
    <div className="px-4 pb-24">
      {/* month nav */}
      <div className="flex items-center justify-between mb-3 px-1">
        <button onClick={() => goMonth(-1)} className="p-1.5 rounded-full" style={{ color: C.inkSoft }}>
          <ChevronLeft size={20} />
        </button>
        <span style={{ fontFamily: "'Shippori Mincho', serif", fontWeight: 700, fontSize: 17, color: C.ink }}>
          {y}年{m + 1}月
        </span>
        <button onClick={() => goMonth(1)} className="p-1.5 rounded-full" style={{ color: C.inkSoft }}>
          <ChevronRight size={20} />
        </button>
      </div>

      {/* legend */}
      <div className="flex gap-3 mb-3 px-1">
        {EVENT_TYPES.map((t) => (
          <div key={t.v} className="flex items-center gap-1">
            <span className="w-1.5 h-1.5 rounded-full" style={{ background: t.color }} />
            <span className="text-[11px]" style={{ color: C.inkSoft }}>{t.label}</span>
          </div>
        ))}
      </div>

      {/* grid */}
      <div
        className="rounded-2xl p-2.5 mb-4"
        style={{ background: C.paperRaised, border: `1px solid ${C.hairline}` }}
      >
        <div className="grid grid-cols-7 mb-1">
          {WEEKDAYS.map((w, i) => (
            <div
              key={w}
              className="text-center text-[11px] py-1"
              style={{ color: i === 0 ? C.coral : i === 6 ? C.indigo : C.mute }}
            >
              {w}
            </div>
          ))}
        </div>
        <div className="grid grid-cols-7 gap-y-1">
          {cells.map((cell, i) => {
            const dateStr = fmtDate(cell.y, cell.m, cell.d);
            const dayEvents = byDate[dateStr] || [];
            const isToday = dateStr === today;
            const isSelected = dateStr === selected;
            const shown = dayEvents.slice(0, 3);
            const overflow = dayEvents.length - shown.length;
            return (
              <div
                key={i}
                onClick={() => setSelected(dateStr)}
                className="flex flex-col items-stretch rounded-lg px-0.5 pt-1 pb-1.5"
                style={{
                  opacity: cell.inMonth ? 1 : 0.32,
                  background: isSelected ? C.indigoSoft : "transparent",
                  cursor: "pointer",
                }}
              >
                <span
                  className="w-5 h-5 flex items-center justify-center rounded-full text-[11px] mb-0.5 self-start ml-0.5"
                  style={{
                    background: isToday ? C.indigo : "transparent",
                    color: isToday ? "#fff" : C.ink,
                    fontWeight: isToday || isSelected ? 700 : 400,
                    fontFamily: "'Zen Kaku Gothic New', sans-serif",
                  }}
                >
                  {cell.d}
                </span>
                <div className="flex flex-col gap-[2px]">
                  {shown.map((e) => {
                    const meta = eventTypeMeta(e.type);
                    return (
                      <button
                        key={e.id}
                        onClick={(ev) => {
                          ev.stopPropagation();
                          setSelected(dateStr);
                        }}
                        className="text-left rounded-[4px] px-1 py-[1px] truncate"
                        style={{
                          background: meta.color,
                          color: "#fff",
                          fontSize: 9,
                          lineHeight: "13px",
                          fontFamily: "'Zen Kaku Gothic New', sans-serif",
                        }}
                        title={eventChipLabel(e)}
                      >
                        {e.companyName || e.title || meta.label}
                      </button>
                    );
                  })}
                  {overflow > 0 && (
                    <span
                      className="text-[9px] px-1"
                      style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}
                    >
                      +{overflow}件
                    </span>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      {/* selected day list */}
      <div>
        <div className="flex items-center justify-between mb-2 px-1">
          <span className="text-[12px]" style={{ color: C.inkSoft, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}>
            {selected.replace(/-/g, "/")} の予定
          </span>
          <button
            onClick={() => setShowAddEvent(true)}
            className="text-[12px] px-2.5 py-1 rounded-full flex items-center gap-1"
            style={{ background: C.indigoSoft, color: C.indigo, fontFamily: "'Zen Kaku Gothic New', sans-serif" }}
          >
            <Plus size={13} /> この日に追加
          </button>
        </div>
        {selectedEvents.length === 0 ? (
          <p className="text-[12px] px-1" style={{ color: C.mute }}>
            予定はありません
          </p>
        ) : (
          <div className="space-y-2">
            {selectedEvents.map((e) => {
              const meta = eventTypeMeta(e.type);
              return (
                <button
                  key={e.id}
                  onClick={() => (e.source === "general" ? onOpenGeneralEvent(e.id) : onOpenCompany(e.companyId))}
                  className="w-full text-left flex items-center gap-3 rounded-xl p-3"
                  style={{ background: C.paperRaised, border: `1px solid ${C.hairline}` }}
                >
                  <span className="w-2 h-2 rounded-full shrink-0" style={{ background: meta.color }} />
                  {e.photo && (
                    <img src={e.photo} alt="" className="w-9 h-9 rounded-lg object-cover shrink-0" />
                  )}
                  <div className="flex-1 min-w-0">
                    <div className="text-[13px] truncate" style={{ color: C.ink, fontWeight: 600 }}>
                      {eventChipLabel(e)}
                    </div>
                    <div className="text-[11px] truncate" style={{ color: C.inkSoft }}>
                      {e.companyName || "個人の予定"}
                      {e.time ? ` ・ ${e.time}` : ""}
                      {e.type === "test" && e.testMethod ? ` ・ ${e.testMethod === "その他" ? e.testMethodOther || "その他" : e.testMethod}` : ""}
                      {e.location ? ` ・ ${e.location}` : ""}
                    </div>
                  </div>
                  <ChevronRight size={16} style={{ color: C.mute }} />
                </button>
              );
            })}
          </div>
        )}
      </div>

      {showAddEvent && (
        <AddEventModal
          companies={companies}
          date={selected}
          onAdd={(companyId, event) => (companyId ? onAddEvent(companyId, event) : onAddGeneralEvent(event))}
          onClose={() => setShowAddEvent(false)}
        />
      )}
    </div>
  );
}

