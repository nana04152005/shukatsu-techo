        </div>

        <Label>種類</Label>
        <div className="flex flex-wrap gap-1.5 mb-3">
          {EVENT_TYPES.map((t) => (
            <button
              key={t.v}
              onClick={() => update({ type: t.v })}
              className="text-[12px] px-2.5 py-1.5 rounded-full"
              style={{
                background: ev.type === t.v ? t.color : C.paperRaised,
                color: ev.type === t.v ? "#fff" : C.inkSoft,
                border: `1px solid ${ev.type === t.v ? t.color : C.hairline}`,
                fontFamily: "'Zen Kaku Gothic New', sans-serif",
              }}
            >
              {t.label}
            </button>
