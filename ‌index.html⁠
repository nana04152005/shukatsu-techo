            label="選考中"
            value={stats.active}
            color={C.indigo}
            bg={C.indigoSoft}
            active={view === "list" && filter === "active"}
            onClick={() => {
              setView("list");
              setFilter("active");
            }}
          />
          <StatPill
            label="内定"
            value={stats.offer}
            color={C.sage}
            bg={C.sageSoft}
            active={view === "list" && filter === "offer"}
            onClick={() => {
              setView("list");
              setFilter("offer");
            }}
          />
