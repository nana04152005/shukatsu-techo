  useEffect(() => {
    if (!loaded) return;
    window.storage.set("companies", JSON.stringify(companies), false).catch(() => {});
  }, [companies, loaded]);

  return [companies, setCompanies, loaded];
}

/* ---------- storage: industry history ---------- */
function useIndustryHistory() {
  const [history, setHistory] = useState([]);
  const [loaded, setLoaded] = useState(false);

  useEffect(() => {
    (async () => {
      try {
        const res = await window.storage.get("industryHistory", false);
        setHistory(res ? JSON.parse(res.value) : []);
      } catch {
        setHistory([]);
      }
      setLoaded(true);
    })();
  }, []);

  useEffect(() => {
    if (!loaded) return;
    window.storage.set("industryHistory", JSON.stringify(history), false).catch(() => {});
  }, [history, loaded]);

  const record = (name) => {
    const v = (name || "").trim();
    if (!v) return;
    setHistory((prev) => (prev.includes(v) ? prev : [...prev, v]));
  };
  const remove = (name) => {
    setHistory((prev) => prev.filter((h) => h !== name));
  };

  return [history, record, remove];
}

