        <CalendarView
          companies={companies}
          generalEvents={generalEvents}
          onOpenCompany={setOpenId}
          onAddEvent={addEventToCompany}
          onAddGeneralEvent={addGeneralEvent}
          onOpenGeneralEvent={setOpenGeneralEventId}
        />
