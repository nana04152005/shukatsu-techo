    });
  };
  const updateEvent = (id, patch) => {
    update({ events: (c.events || []).map((ev) => (ev.id === id ? { ...ev, ...patch } : ev)) });
  };
  const deleteEvent = (id) => {
    update({ events: (c.events || []).filter((ev) => ev.id !== id) });
  };

  const addES = () => {
    update({ es: [...(c.es || []), { id: uid(), q: "", a: "", limit: 400 }] });
